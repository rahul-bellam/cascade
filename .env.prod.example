# Cascade — production env template.
# Copy to .env.prod and fill in REAL secrets. .env.prod is gitignored.
# Used by: docker compose -f docker-compose.prod.yml --env-file .env.prod up -d

# ─── Datastores ──────────────────────────────────────────────────────────────
# If using the bundled postgres/redis containers, DATABASE_URL host = "postgres",
# REDIS_URL host = "redis" (the compose service names).
# If using managed DBs (Neon/Supabase, Upstash), paste their connection strings
# here and delete the postgres/redis services from docker-compose.prod.yml.
POSTGRES_DB=cascade
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_strong_password
DATABASE_URL=postgres://postgres:CHANGE_ME_strong_password@postgres:5432/cascade?sslmode=disable
REDIS_URL=redis://redis:6379

# ─── Auth / Security ─────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_long_random_secret   # openssl rand -hex 32
JWT_EXPIRY=24h

# ─── Service ports (host:container) — override only if you need to ────────────
AUTH_PORT=8081
USER_PORT=8082
LEARN_ENGINE_PORT=8093
CASCADE_ENGINE_PORT=8090
CONSTRAINT_ENGINE_PORT=8094
REFACTOR_ENGINE_PORT=8095
ARENA_ENGINE_PORT=8096
INSIGHT_ENGINE_PORT=8097

APP_ENV=production
LOG_LEVEL=info

# Cascade — Environment Configuration (example)
# Copy this file to `.env` and adjust values for your local setup.
# `.env` is gitignored; never commit real secrets.

# ─── Core Infrastructure (matches docker-compose.yml) ───────────────────────
# PostgreSQL
POSTGRES_DB=cascade
POSTGRES_USER=postgres
POSTGRES_PASSWORD=cascade_dev
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgres://postgres:cascade_dev@localhost:5432/cascade?sslmode=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# MinIO (S3-compatible object storage)
MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=cascade
MINIO_ROOT_PASSWORD=cascade_dev
MINIO_USE_SSL=false

# ─── Backend Service Ports ──────────────────────────────────────────────────
# Go services
AUTH_PORT=8081
USER_PORT=8082
CONTENT_PORT=8083
CONSTRAINT_ENGINE_PORT=8094
ARENA_ENGINE_PORT=8096

# Python services
LEARN_ENGINE_PORT=8093
CASCADE_ENGINE_PORT=8090
REFACTOR_ENGINE_PORT=8095

# ─── Frontend ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# ─── Auth / Security (placeholders — replace in real deployments) ────────────
JWT_SECRET=dev-only-change-me
JWT_EXPIRY=24h

# ─── Environment ────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=debug
